### Variables
@baseUrl = http://localhost:3000/api
@token = YOUR_ACCESS_TOKEN

### Register
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123",
  "first_name": "Jean",
  "last_name": "Dupont",
  "birthdate": "1990-01-01"
}

### Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

### Get Current User
GET {{baseUrl}}/auth/me
Authorization: Bearer {{token}}

### Update User
PUT {{baseUrl}}/auth/update
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "first_name": "Jean Updated"
}

### Get All Restaurants
GET {{baseUrl}}/restaurants

### Create Restaurant
POST {{baseUrl}}/restaurants
Content-Type: application/json

{
  "owner_id": "uuid-user-id",
  "name": "Ma Restaurant",
  "email": "resto@test.com",
  "phone": "0123456789"
}

### Get Restaurant by ID
GET {{baseUrl}}/restaurants/1

### Get All Dishes
GET {{baseUrl}}/dishes

### Create Dish
POST {{baseUrl}}/dishes
Content-Type: application/json

{
  "restaurant_id": 1,
  "name": "Pizza Margherita",
  "price": 15.99,
  "description": "Pizza traditionnelle"
}